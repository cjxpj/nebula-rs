    "version": "0.2.0",
    "configurations": [
        {
            "type": "nr-debug",
            "request": "launch",
            "name": "NR 调试",
            "program": "dicTest/dic.nr",
            "stopOnEntry": false
        },
        {
            "name": "Debug executable 'nebula'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=nebula"
                ]
            },
            "args": [
                "--debug",
                "dicTest/dic.nr"
            ]
        },
        {
            "name": "Debug unit tests in executable 'nebula'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=nebula"
                ]
            },
            "args": [
                "dicTest/dic.nr"
            ]
        }
    ]
}