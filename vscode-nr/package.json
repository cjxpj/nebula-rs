{
  "name": "nr-language",
  "displayName": "NR Language Support",
  "description": "NR 语言 (Nebula 词库引擎 DSL) 语法高亮与代码补全支持",
  "version": "1.0.1",
  "publisher": "nebula",
  "icon": "icon.png",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "repository": {
    "type": "git",
    "url": "https://github.com/nebula/nr-language"
  },
  "contributes": {
    "commands": [
      {
        "command": "nr.checkUpdate",
        "title": "NR: 检查更新"
      }
    ],
    "languages": [
      {
        "id": "nr",
        "aliases": ["NR", "nr"],
        "extensions": [".nr"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nr",
        "scopeName": "source.nr",
        "path": "./syntaxes/nr.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nr",
        "path": "./snippets/nr.json"
      }
    ],
    "completions": [
      {
        "language": "nr",
        "items": [
          { "label": "字符串.", "detail": "字符串操作 — 需 #引入=@字符串", "kind": 8 },
          { "label": "类型.", "detail": "类型转换 — 需 #引入=@类型", "kind": 8 },
          { "label": "数学.", "detail": "数学运算 — 需 #引入=@数学", "kind": 8 },
          { "label": "访问.", "detail": "HTTP 网络访问 — 需 #引入=@访问", "kind": 8 }
        ]
      }
    ]
  }
}
